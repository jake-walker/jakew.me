---
import { Icon } from "astro-icon/components";

interface Props {
  extraLinks?: { title: string; href: string; icon?: string }[];
}

const { extraLinks } = Astro.props;
---

<div class="bg-zinc-200 text-zinc-600 dark:bg-zinc-900 dark:text-zinc-400">
  <div class="container mx-auto px-4 py-4 grid grid-cols-2">
    <div>
      <a class="font-bold text-lg" href="/">Jake Walker</a>
    </div>
    <div class="text-right">
      <p class="text-sm">
        <a
          href="https://github.com/jake-walker/jakew.me"
          class="underline hover:no-underline">Source code</a
        > is licensed under the <a
          href="https://opensource.org/licenses/MIT"
          class="underline hover:no-underline">MIT License</a
        >.
      </p>
      <p class="text-sm">
        Blog content is licensed under <a
          rel="license"
          href="https://creativecommons.org/licenses/by/4.0/"
          class="underline hover:no-underline"
          ><Icon name="tabler:creative-commons-by" class="inline size-5" /> CC BY
          4.0</a
        >.
      </p>
      <p class="text-xs mt-2">
        {
          [
            {
              title: "RSS",
              href: new URL("rss", Astro.site),
              icon: "tabler:rss",
            },
            ...(extraLinks ?? []),
          ].map((link, i) => (
            <a
              href={link.href}
              class="underline hover:no-underline"
              class:list={[i > 0 && "ms-2"]}
            >
              {link.icon && <Icon name={link.icon} class="inline size-4" />}
              {link.title}
            </a>
          ))
        }
      </p>
    </div>
  </div>
</div>
